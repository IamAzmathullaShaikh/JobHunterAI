# Application Port configuration
PORT=3000

# Server environment mode (development or production)
NODE_ENV=development

# Google Gemini API Key (Retrieve yours from https://aistudio.google.com/)
# CRITICAL: Keep this server-side only. DO NOT prefix with VITE_
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite or database files location configuration
DB_PATH=./db.json

# AI Provider configuration
AI_PROVIDER=groq  # Options: groq, openrouter, ollama, gemini

# Groq API Key (if using Groq)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (if using OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Host (if using Ollama)
OLLAMA_HOST=http://localhost:11434/v1
