# Application Port configuration
PORT=8000

# Server environment mode (development or production)
NODE_ENV=development

# Google Gemini API Key (Retrieve yours from https://aistudio.google.com/)
# CRITICAL: Keep this server-side only. DO NOT prefix with VITE_
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite or database files location configuration
DATABASE_URL=sqlite+aiosqlite:///./jobhunter.db

# Apify Cloud scraper engine (optional). Get a token from the Apify Console
# (Settings > API & Integrations). The engine runs a pay-per-result actor,
# so light use is covered by the free monthly credit. Leave blank to disable.
APIFY_API_TOKEN=your_apify_api_token_here

# Groq API Key (for fast, free inference)
GROQ_API_KEY=your_groq_api_key_here
AI_PROVIDER=groq
