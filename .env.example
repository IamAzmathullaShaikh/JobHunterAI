# Application Port configuration
PORT=3000

# Server environment mode (development or production)
NODE_ENV=development

# Google Gemini API Key (Retrieve yours from https://aistudio.google.com/)
# CRITICAL: Keep this server-side only. DO NOT prefix with VITE_
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite or database files location configuration
DB_PATH=./db.json

# Gemini Model configuration
GEMINI_MODEL=gemini-3.5-flash
